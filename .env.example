# Supabase project credentials (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Provisioning / type-gen only (not read by app code yet): service role + project ref
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_ID=your-supabase-project-ref
# Comma-separated allowlist of admin emails permitted into /admin
ADMIN_EMAILS=you@example.com
# Used for SEO canonical/OG URLs in the public site (Plan 2)
# Absolute share/OG image URLs and canonicals derive from this — set it in
# production, or those links will point at localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
